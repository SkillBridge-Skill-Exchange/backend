# ========================
# SkillBridge Environment
# ========================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# Database (MySQL — each developer uses their own local DB)
DB_NAME=skillbridge
DB_USER=root
DB_PASS=yourpassword
DB_HOST=localhost
DB_PORT=3306

# JWT
JWT_SECRET=secret
JWT_EXPIRES_IN=7d
